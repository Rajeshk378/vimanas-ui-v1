# Vimanas API Configuration
REACT_APP_VIMANAS_API_URL=http://localhost:8000/api/v1

# Optional: WebSocket URL for real-time features
REACT_APP_WEBSOCKET_URL=ws://localhost:8000

# Optional: Application Configuration
REACT_APP_APP_NAME=AI Interview Panel
REACT_APP_VERSION=1.0.0

# Optional: Feature Flags
REACT_APP_ENABLE_CODING_TESTS=true
REACT_APP_ENABLE_OFFER_NEGOTIATION=true
REACT_APP_ENABLE_ANALYTICS=true

# Optional: Audio Configuration
REACT_APP_DEFAULT_AUDIO_FORMAT=mp3
REACT_APP_SPEECH_RECOGNITION_LANG=en-US

# Optional: Interview Configuration
REACT_APP_DEFAULT_INTERVIEW_DURATION=3600
REACT_APP_SKILL_TRANSITION_INTERVAL=600